# Copy this to .env and fill in your values
DATABASE_URL="mysql://pms_user:YOUR_DB_PASS@localhost:3306/serene_pms"

# DigitalOcean Spaces
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_KEY=YOUR_DO_KEY
DO_SPACES_SECRET=YOUR_DO_SECRET
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_REGION=sgp1
DO_SPACES_CDN_URL=https://your-bucket.sgp1.cdn.digitaloceanspaces.com
SHADOW_DATABASE_URL="mysql://root:YOUR_ROOT_PASS@localhost:3306/serene_pms_shadow"

# JWT — use long random strings in production
JWT_SECRET="CHANGE_THIS_TO_LONG_RANDOM_SECRET_MIN_64_CHARS"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_SECRET="CHANGE_THIS_REFRESH_SECRET_MIN_64_CHARS"
JWT_REFRESH_EXPIRES_IN="30d"

PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
