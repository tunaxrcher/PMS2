generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ============================================================
// PROPERTY & STRUCTURE
// ============================================================

model Property {
  id                  String      @id @default(uuid())
  name                String      @db.VarChar(200)
  propertyType        String      @default("resort") @map("property_type") @db.VarChar(50)
  address             String?     @db.Text
  phone               String?     @db.VarChar(50)
  email               String?     @db.VarChar(200)
  timezone            String      @default("Asia/Bangkok") @db.VarChar(100)
  checkInTime         String      @default("14:00") @map("check_in_time") @db.VarChar(10)
  checkOutTime        String      @default("12:00") @map("check_out_time") @db.VarChar(10)
  vatRate             Decimal     @default(7.00) @map("vat_rate") @db.Decimal(5, 2)
  serviceChargeRate   Decimal     @default(0.00) @map("service_charge_rate") @db.Decimal(5, 2)
  priceIncludeTax     Boolean     @default(true) @map("price_include_tax")
  active              Boolean     @default(true)
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  users               User[]
  zones               Zone[]
  roomTypes           RoomType[]
  rooms               Room[]
  bookings            Booking[]
  bookingSources      BookingSource[]
  housekeepingTasks   HousekeepingTask[]
  maintenanceTickets  MaintenanceTicket[]
  ratePlans           RatePlan[]
  dailyRates          DailyRate[]
  inventory           Inventory[]
  packages            Package[]
  auditLogs           AuditLog[]
  guests              Guest[]

  @@map("properties")
}

model Zone {
  id            String    @id @default(uuid())
  propertyId    String    @map("property_id")
  name          String    @db.VarChar(200)
  zoneType      String    @default("other") @map("zone_type") @db.VarChar(50)
  imageUrl      String?   @map("image_url") @db.VarChar(500)
  parentZoneId  String?   @map("parent_zone_id")
  sortOrder     Int       @default(0) @map("sort_order")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  property  Property  @relation(fields: [propertyId], references: [id])
  parent    Zone?     @relation("ZoneParent", fields: [parentZoneId], references: [id])
  children  Zone[]    @relation("ZoneParent")
  rooms     Room[]

  @@index([propertyId])
  @@map("zones")
}

model RoomType {
  id              String    @id @default(uuid())
  propertyId      String    @map("property_id")
  name            String    @db.VarChar(200)
  description     String?   @db.Text
  imageUrl        String?   @map("image_url") @db.VarChar(500)
  baseOccupancy   Int       @default(2) @map("base_occupancy")
  maxOccupancy    Int       @default(4) @map("max_occupancy")
  baseRate        Decimal   @default(0.00) @map("base_rate") @db.Decimal(12, 2)
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  property      Property        @relation(fields: [propertyId], references: [id])
  rooms         Room[]
  bookingRooms  BookingRoom[]
  ratePlans     RatePlan[]
  dailyRates    DailyRate[]
  inventory     Inventory[]

  @@index([propertyId])
  @@map("room_types")
}

model Room {
  id              String      @id @default(uuid())
  propertyId      String      @map("property_id")
  roomTypeId      String      @map("room_type_id")
  zoneId          String?     @map("zone_id")
  roomNumber      String      @map("room_number") @db.VarChar(50)
  roomName        String?     @map("room_name") @db.VarChar(200)
  floorNo         String?     @map("floor_no") @db.VarChar(20)
  buildingName    String?     @map("building_name") @db.VarChar(100)
  maxOccupancy    Int         @default(4) @map("max_occupancy")
  currentStatus   String      @default("clean") @map("current_status") @db.VarChar(50)
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  property          Property            @relation(fields: [propertyId], references: [id])
  roomType          RoomType            @relation(fields: [roomTypeId], references: [id])
  zone              Zone?               @relation(fields: [zoneId], references: [id])
  bookingRooms      BookingRoom[]
  housekeepingTasks HousekeepingTask[]
  maintenanceTickets MaintenanceTicket[]
  roomStatusLogs    RoomStatusLog[]
  images            RoomImage[]

  @@unique([propertyId, roomNumber])
  @@index([propertyId])
  @@index([roomTypeId])
  @@map("rooms")
}

model RoomStatusLog {
  id          String    @id @default(uuid())
  roomId      String    @map("room_id")
  oldStatus   String    @map("old_status") @db.VarChar(50)
  newStatus   String    @map("new_status") @db.VarChar(50)
  reason      String?   @db.VarChar(500)
  changedBy   String    @map("changed_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  room  Room  @relation(fields: [roomId], references: [id])

  @@index([roomId])
  @@map("room_status_logs")
}

model RoomImage {
  id          String    @id @default(uuid())
  roomId      String    @map("room_id")
  url         String    @db.VarChar(500)
  caption     String?   @db.VarChar(200)
  sortOrder   Int       @default(0) @map("sort_order")
  isPrimary   Boolean   @default(false) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at")

  room  Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("room_images")
}

// ============================================================
// USER & PERMISSION
// ============================================================

model User {
  id                    String    @id @default(uuid())
  propertyId            String?   @map("property_id")
  phone                 String    @unique @db.VarChar(20)
  firstName             String    @map("first_name") @db.VarChar(100)
  lastName              String    @map("last_name") @db.VarChar(100)
  pinHash               String    @map("pin_hash") @db.VarChar(255)
  active                Boolean   @default(true)
  mustChangePinOnLogin  Boolean   @default(true) @map("must_change_pin_on_login")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  property    Property?   @relation(fields: [propertyId], references: [id])
  userRoles   UserRole[]

  @@index([propertyId])
  @@map("users")
}

model Role {
  id          String    @id @default(uuid())
  name        String    @unique @db.VarChar(100)
  displayName String    @map("display_name") @db.VarChar(200)
  createdAt   DateTime  @default(now()) @map("created_at")

  userRoles         UserRole[]
  rolePermissions   RolePermission[]

  @@map("roles")
}

model Permission {
  id          String    @id @default(uuid())
  code        String    @unique @db.VarChar(200)
  name        String    @db.VarChar(200)
  createdAt   DateTime  @default(now()) @map("created_at")

  rolePermissions   RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String    @map("user_id")
  roleId    String    @map("role_id")
  createdAt DateTime  @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId        String    @map("role_id")
  permissionId  String    @map("permission_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  role        Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission  Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// GUEST
// ============================================================

model Guest {
  id            String    @id @default(uuid())
  propertyId    String    @map("property_id")
  firstName     String    @map("first_name") @db.VarChar(100)
  lastName      String    @map("last_name") @db.VarChar(100)
  phone         String?   @db.VarChar(50)
  email         String?   @db.VarChar(200)
  nationality   String?   @db.VarChar(100)
  idType        String?   @map("id_type") @db.VarChar(50)
  idNumber      String?   @map("id_number") @db.VarChar(50)
  dateOfBirth   DateTime? @map("date_of_birth") @db.Date
  address       String?   @db.Text
  remark        String?   @db.Text
  blacklistFlag Boolean   @default(false) @map("blacklist_flag")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  property  Property  @relation(fields: [propertyId], references: [id])
  bookings  Booking[]
  folios    Folio[]

  @@index([propertyId])
  @@index([phone])
  @@map("guests")
}

// ============================================================
// BOOKING
// ============================================================

model BookingSource {
  id          String    @id @default(uuid())
  propertyId  String    @map("property_id")
  name        String    @db.VarChar(200)
  sourceType  String    @default("direct") @map("source_type") @db.VarChar(50)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  property  Property  @relation(fields: [propertyId], references: [id])
  bookings  Booking[]

  @@index([propertyId])
  @@map("booking_sources")
}

model Booking {
  id                String    @id @default(uuid())
  propertyId        String    @map("property_id")
  bookingNumber     String    @unique @map("booking_number") @db.VarChar(50)
  guestId           String    @map("guest_id")
  bookingSourceId   String?   @map("booking_source_id")
  status            String    @default("confirmed") @map("status") @db.VarChar(50)
  checkInDate       DateTime  @map("check_in_date") @db.Date
  checkOutDate      DateTime  @map("check_out_date") @db.Date
  adults            Int       @default(1)
  children          Int       @default(0)
  packageName       String?   @map("package_name") @db.VarChar(200)
  packageDetailJson Json?     @map("package_detail_json")
  packageNote       String?   @map("package_note") @db.Text
  notes             String?   @db.Text
  noShowMarkedBy    String?   @map("no_show_marked_by")
  noShowMarkedAt    DateTime? @map("no_show_marked_at")
  noShowFee         Decimal?  @map("no_show_fee") @db.Decimal(12, 2)
  createdBy         String    @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  property      Property              @relation(fields: [propertyId], references: [id])
  guest         Guest                 @relation(fields: [guestId], references: [id])
  bookingSource BookingSource?        @relation(fields: [bookingSourceId], references: [id])
  bookingRooms  BookingRoom[]
  folios        Folio[]
  deposits      Deposit[]
  cancellation  BookingCancellation?
  statusLogs    BookingStatusLog[]
  rateAdjustments RateAdjustment[]

  @@index([propertyId])
  @@index([status])
  @@index([checkInDate])
  @@index([checkOutDate])
  @@index([guestId])
  @@map("bookings")
}

model BookingRoom {
  id            String    @id @default(uuid())
  bookingId     String    @map("booking_id")
  roomTypeId    String    @map("room_type_id")
  roomId        String?   @map("room_id")
  checkInDate   DateTime  @map("check_in_date") @db.Date
  checkOutDate  DateTime  @map("check_out_date") @db.Date
  adults        Int       @default(1)
  children      Int       @default(0)
  rate          Decimal   @db.Decimal(12, 2)
  status        String    @default("confirmed") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomType  RoomType  @relation(fields: [roomTypeId], references: [id])
  room      Room?     @relation(fields: [roomId], references: [id])

  @@index([bookingId])
  @@index([roomTypeId])
  @@index([roomId])
  @@index([checkInDate])
  @@index([checkOutDate])
  @@map("booking_rooms")
}

model BookingCancellation {
  id                String    @id @default(uuid())
  bookingId         String    @unique @map("booking_id")
  reason            String    @db.Text
  cancelledBy       String    @map("cancelled_by")
  cancelledAt       DateTime  @default(now()) @map("cancelled_at")
  refundAmount      Decimal?  @map("refund_amount") @db.Decimal(12, 2)
  cancellationFee   Decimal?  @map("cancellation_fee") @db.Decimal(12, 2)

  booking   Booking   @relation(fields: [bookingId], references: [id])

  @@map("booking_cancellations")
}

model BookingStatusLog {
  id          String    @id @default(uuid())
  bookingId   String    @map("booking_id")
  oldStatus   String    @map("old_status") @db.VarChar(50)
  newStatus   String    @map("new_status") @db.VarChar(50)
  changedBy   String    @map("changed_by")
  remark      String?   @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_status_logs")
}

// ============================================================
// BILLING
// ============================================================

model Folio {
  id          String    @id @default(uuid())
  bookingId   String    @map("booking_id")
  folioCode   String    @default("A") @map("folio_code") @db.VarChar(10)
  folioType   String    @default("master") @map("folio_type") @db.VarChar(50)
  guestId     String?   @map("guest_id")
  status      String    @default("open") @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at")
  closedAt    DateTime? @map("closed_at")

  booking   Booking     @relation(fields: [bookingId], references: [id])
  guest     Guest?      @relation(fields: [guestId], references: [id])
  items     FolioItem[]
  payments  Payment[]
  deposits  Deposit[]

  @@index([bookingId])
  @@map("folios")
}

model FolioItem {
  id          String    @id @default(uuid())
  folioId     String    @map("folio_id")
  itemType    String    @map("item_type") @db.VarChar(50)
  description String    @db.VarChar(500)
  quantity    Int       @default(1)
  unitPrice   Decimal   @map("unit_price") @db.Decimal(12, 2)
  totalAmount Decimal   @map("total_amount") @db.Decimal(12, 2)
  serviceDate DateTime  @map("service_date") @db.Date
  createdBy   String    @map("created_by")
  isVoided    Boolean   @default(false) @map("is_voided")
  createdAt   DateTime  @default(now()) @map("created_at")

  folio   Folio   @relation(fields: [folioId], references: [id])

  @@index([folioId])
  @@index([serviceDate])
  @@map("folio_items")
}

model Payment {
  id              String    @id @default(uuid())
  folioId         String    @map("folio_id")
  paymentMethod   String    @map("payment_method") @db.VarChar(50)
  amount          Decimal   @db.Decimal(12, 2)
  paidAt          DateTime  @default(now()) @map("paid_at")
  referenceNo     String?   @map("reference_no") @db.VarChar(200)
  receivedBy      String    @map("received_by")
  status          String    @default("paid") @db.VarChar(50)

  folio   Folio    @relation(fields: [folioId], references: [id])
  refunds Refund[]

  @@index([folioId])
  @@index([paymentMethod])
  @@index([paidAt])
  @@index([status])
  @@map("payments")
}

model Refund {
  id          String    @id @default(uuid())
  paymentId   String    @map("payment_id")
  amount      Decimal   @db.Decimal(12, 2)
  reason      String    @db.Text
  refundedBy  String    @map("refunded_by")
  refundedAt  DateTime  @default(now()) @map("refunded_at")

  payment   Payment   @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@map("refunds")
}

model Deposit {
  id              String    @id @default(uuid())
  bookingId       String    @map("booking_id")
  folioId         String?   @map("folio_id")
  amount          Decimal   @db.Decimal(12, 2)
  depositType     String    @map("deposit_type") @db.VarChar(50)
  paymentMethod   String    @map("payment_method") @db.VarChar(50)
  status          String    @default("held") @db.VarChar(50)
  receivedBy      String    @map("received_by")
  receivedAt      DateTime  @default(now()) @map("received_at")
  referenceNo     String?   @map("reference_no") @db.VarChar(200)
  remark          String?   @db.VarChar(500)

  booking   Booking   @relation(fields: [bookingId], references: [id])
  folio     Folio?    @relation(fields: [folioId], references: [id])

  @@index([bookingId])
  @@map("deposits")
}

model RateAdjustment {
  id                String    @id @default(uuid())
  bookingId         String    @map("booking_id")
  oldPrice          Decimal   @map("old_price") @db.Decimal(12, 2)
  newPrice          Decimal   @map("new_price") @db.Decimal(12, 2)
  adjustmentType    String    @map("adjustment_type") @db.VarChar(50)
  reason            String    @db.Text
  approvedByUserId  String?   @map("approved_by_user_id")
  createdBy         String    @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")

  booking   Booking   @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@map("rate_adjustments")
}

// ============================================================
// HOUSEKEEPING & MAINTENANCE
// ============================================================

model HousekeepingTask {
  id          String    @id @default(uuid())
  propertyId  String    @map("property_id")
  roomId      String    @map("room_id")
  taskType    String    @map("task_type") @db.VarChar(50)
  status      String    @default("pending") @db.VarChar(50)
  assignedTo  String?   @map("assigned_to")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  remark      String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  property  Property  @relation(fields: [propertyId], references: [id])
  room      Room      @relation(fields: [roomId], references: [id])

  @@index([propertyId])
  @@index([roomId])
  @@index([status])
  @@map("housekeeping_tasks")
}

model MaintenanceTicket {
  id          String    @id @default(uuid())
  propertyId  String    @map("property_id")
  roomId      String?   @map("room_id")
  issueTitle  String    @map("issue_title") @db.VarChar(300)
  issueDetail String?   @map("issue_detail") @db.Text
  priority    String    @default("medium") @db.VarChar(50)
  status      String    @default("open") @db.VarChar(50)
  reportedBy  String    @map("reported_by")
  resolvedBy  String?   @map("resolved_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  resolvedAt  DateTime? @map("resolved_at")

  property  Property  @relation(fields: [propertyId], references: [id])
  room      Room?     @relation(fields: [roomId], references: [id])

  @@index([propertyId])
  @@index([roomId])
  @@index([status])
  @@map("maintenance_tickets")
}

// ============================================================
// PRICING
// ============================================================

model RatePlan {
  id                    String    @id @default(uuid())
  propertyId            String    @map("property_id")
  roomTypeId            String    @map("room_type_id")
  name                  String    @db.VarChar(200)
  basePrice             Decimal   @map("base_price") @db.Decimal(12, 2)
  mealPlan              String    @default("none") @map("meal_plan") @db.VarChar(50)
  cancellationPolicy    String?   @map("cancellation_policy") @db.Text
  active                Boolean   @default(true)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  property    Property    @relation(fields: [propertyId], references: [id])
  roomType    RoomType    @relation(fields: [roomTypeId], references: [id])
  dailyRates  DailyRate[]

  @@index([propertyId])
  @@index([roomTypeId])
  @@map("rate_plans")
}

model DailyRate {
  id          String    @id @default(uuid())
  propertyId  String    @map("property_id")
  roomTypeId  String    @map("room_type_id")
  ratePlanId  String    @map("rate_plan_id")
  date        DateTime  @db.Date
  price       Decimal   @db.Decimal(12, 2)
  minStay     Int?      @map("min_stay")
  stopSell    Boolean   @default(false) @map("stop_sell")

  property  Property  @relation(fields: [propertyId], references: [id])
  roomType  RoomType  @relation(fields: [roomTypeId], references: [id])
  ratePlan  RatePlan  @relation(fields: [ratePlanId], references: [id])

  @@unique([propertyId, roomTypeId, ratePlanId, date])
  @@index([propertyId, roomTypeId, date])
  @@map("daily_rates")
}

// ============================================================
// INVENTORY
// ============================================================

model Inventory {
  id              String    @id @default(uuid())
  propertyId      String    @map("property_id")
  roomTypeId      String    @map("room_type_id")
  date            DateTime  @db.Date
  totalRooms      Int       @map("total_rooms")
  blockedRooms    Int       @default(0) @map("blocked_rooms")
  bookedRooms     Int       @default(0) @map("booked_rooms")
  availableRooms  Int       @map("available_rooms")

  property  Property  @relation(fields: [propertyId], references: [id])
  roomType  RoomType  @relation(fields: [roomTypeId], references: [id])

  @@unique([propertyId, roomTypeId, date])
  @@index([propertyId, roomTypeId, date])
  @@map("inventory")
}

// ============================================================
// PACKAGES
// ============================================================

model Package {
  id          String    @id @default(uuid())
  propertyId  String    @map("property_id")
  name        String    @db.VarChar(200)
  description String?   @db.Text
  packageType String?   @map("package_type") @db.VarChar(100)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  property      Property        @relation(fields: [propertyId], references: [id])
  items         PackageItem[]
  bookingPkgs   BookingPackage[]

  @@index([propertyId])
  @@map("packages")
}

model PackageItem {
  id              String    @id @default(uuid())
  packageId       String    @map("package_id")
  serviceType     String    @map("service_type") @db.VarChar(100)
  name            String    @db.VarChar(200)
  quantity        Int       @default(1)
  includedPrice   Decimal   @map("included_price") @db.Decimal(12, 2)
  cost            Decimal?  @db.Decimal(12, 2)

  package   Package   @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@map("package_items")
}

model BookingPackage {
  id                    String    @id @default(uuid())
  bookingId             String    @map("booking_id")
  packageId             String    @map("package_id")
  packageSnapshotJson   Json      @map("package_snapshot_json")
  createdAt             DateTime  @default(now()) @map("created_at")

  package   Package   @relation(fields: [packageId], references: [id])

  @@index([bookingId])
  @@map("booking_packages")
}

// ============================================================
// OTA (structure ready, not implemented in MVP)
// ============================================================

model OtaChannel {
  id      String    @id @default(uuid())
  name    String    @unique @db.VarChar(200)
  active  Boolean   @default(true)

  roomTypeMappings  OtaRoomTypeMapping[]
  otaBookings       OtaBooking[]

  @@map("ota_channels")
}

model OtaRoomTypeMapping {
  id                    String    @id @default(uuid())
  propertyId            String    @map("property_id")
  channelId             String    @map("channel_id")
  internalRoomTypeId    String    @map("internal_room_type_id")
  externalRoomTypeId    String    @map("external_room_type_id") @db.VarChar(200)

  channel   OtaChannel  @relation(fields: [channelId], references: [id])

  @@unique([channelId, internalRoomTypeId])
  @@map("ota_room_type_mappings")
}

model OtaBooking {
  id                  String    @id @default(uuid())
  bookingId           String    @map("booking_id")
  channelId           String    @map("channel_id")
  externalBookingId   String    @map("external_booking_id") @db.VarChar(200)
  rawPayloadJson      Json      @map("raw_payload_json")
  createdAt           DateTime  @default(now()) @map("created_at")

  channel   OtaChannel  @relation(fields: [channelId], references: [id])

  @@unique([channelId, externalBookingId])
  @@map("ota_bookings")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id              String    @id @default(uuid())
  propertyId      String?   @map("property_id")
  userId          String?   @map("user_id")
  action          String    @db.VarChar(200)
  entityType      String    @map("entity_type") @db.VarChar(100)
  entityId        String?   @map("entity_id") @db.VarChar(100)
  oldValueJson    Json?     @map("old_value_json")
  newValueJson    Json?     @map("new_value_json")
  ipAddress       String?   @map("ip_address") @db.VarChar(50)
  userAgent       String?   @map("user_agent") @db.VarChar(500)
  createdAt       DateTime  @default(now()) @map("created_at")

  property  Property?   @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
